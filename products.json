{
  "_meta": {
    "purpose": "本地化经理负责的产品 → GitLab 仓库 / 本地化文件格式 注册表。供「GitLab 产品仓库全量基线摄取」(Phase 1b) 使用：按产品拉取已合并的全套 locale 文件，解析出 (opus_id, en-US 源, 各语言译文) 灌入本地索引 opus_index.db，使 OPUS 搜索从「最新但不全」升级为「最新 + 最全」。",
    "background": "Tranzor 上线后翻译只回写 GitLab 产品仓库，不再回写旧 OPUS/loc-central，故 l10n-tool HTTP 目录的全量包 (UNS.zip 等) 严重滞后。GitLab 产品仓库才是唯一「最新 + 最全」的数据源。详见项目记忆 project-loc-full-export-pivot。",
    "opus_id_algorithm": "RingCentral.{alias}.{md5(sourceRelativePath)}.{logicalKey} —— 已用真实 opus_index.db 交叉验证：path_hash == md5(源相对路径)（无归一化，UTF-8）。每个产品最大的正确性工作量是复刻其 sourceRelativePath 字符串约定（与 l10n-cli 一致），否则重建出的 opus_id 对不上。",
    "alias_source": "aliases 与 gitlab 路径来自真实 opus_index.db 的 alias / project_id 字段交叉比对（截至 2026-06-09，库内约 127 万行）。verified=false 的条目需在 Phase 1b 实接仓库时确认 group、default_branch、locale_globs、format。",
    "gitlab_base": "https://git.ringcentral.com",
    "source_locale": "en-US",
    "default_branch_note": "default_branch 暂统一标 master，摄取时应改为通过 GitLab API 解析各仓库真实默认分支。",
    "supported_locales_tierA": ["de-DE", "en-AU", "en-GB", "en-US", "es-ES", "es-419", "fr-FR", "fr-CA", "it-IT", "nl-NL", "pt-BR", "pt-PT", "fi-FI", "ko-KR", "ja-JP", "zh-CN", "zh-TW", "zh-HK"]
  },
